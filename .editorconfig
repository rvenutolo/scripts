root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bash}]
indent_style = space
indent_size = 2
switch_case_indent = true
binary_next_line = true
space_redirects = true

[*.md]
trim_trailing_whitespace = false

[.gitmodules]
indent_style = tab
indent_size = unset
