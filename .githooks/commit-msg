#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::check_exactly_1_arg "$@"

readonly COMMIT_MSG_FILE="$1"

if ! commands::executable_exists 'commitlint'; then
  log::warn 'commit-msg: commitlint not found — skipping commitlint check'
  exit 0
fi

log::log 'commit-msg: running commitlint'
commitlint --edit "${COMMIT_MSG_FILE}"
