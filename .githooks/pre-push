#!/usr/bin/env bash

# @description Git pre-push hook. Runs check-scripts (shellcheck + shdoc audit), nix flake check (formatting), and the governance lint suite inside the flake devShell, aborting the push if any fails. Bypass with `git push --no-verify`.
# @arg $@ args git passes ref/sha pairs that this hook does not use
# @exitcode 0 check-scripts, nix flake check, and governance checks passed
# @exitcode 1 check-scripts, nix flake check, or governance checks failed; push aborted

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
# check-scripts and .ci/ live at the repo root, not under SCRIPTS_DIR (= repo-root/scripts).
REPO_DIR="$(git rev-parse --show-toplevel)"
readonly REPO_DIR
log::enable_err_trap
# pass-through: git passes ref/sha pairs on stdin we ignore

log::log 'pre-push: running check-scripts'
if ! nix develop --command "${REPO_DIR}/check-scripts"; then
  log::die 'check-scripts failed — push aborted. Fix issues or rerun with --no-verify to bypass.'
fi
log::log 'pre-push: check-scripts passed'

log::log 'pre-push: running nix flake check'
if ! nix flake check; then
  log::die 'nix flake check failed — push aborted. Run nix fmt to format, or rerun with --no-verify to bypass.'
fi
log::log 'pre-push: nix flake check passed'

log::log 'pre-push: running governance checks'
if ! nix develop --command "${REPO_DIR}/.ci/run-governance-checks"; then
  log::die 'governance checks failed — push aborted. Fix issues or rerun with --no-verify to bypass.'
fi
log::log 'pre-push: governance checks passed'
