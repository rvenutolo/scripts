#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_least_2_args "$@"
args::check_at_most_3_args "$@"

if [[ "$#" -eq 3 ]]; then
  readonly num_output="$3"
else
  readonly num_output=1
fi

shuf --input-range "$1-$2" --head-count "${num_output}"
