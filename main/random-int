#!/usr/bin/env bash

# @description Print one or more random integers drawn (without replacement) from the inclusive range `[min, max]`.
# @arg $1 min Inclusive lower bound of the range.
# @arg $2 max Inclusive upper bound of the range.
# @arg $3 count Optional number of integers to emit (default 1).
# @stdout Random integers, one per line.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_at_least_2_args "$@"
args::check_at_most_3_args "$@"
readonly MIN="$1"
readonly MAX="$2"

if args::has_num_args 3 "$@"; then
  readonly NUM_OUTPUT="$3"
else
  readonly NUM_OUTPUT=1
fi

shuf --input-range "${MIN}-${MAX}" --head-count "${NUM_OUTPUT}"
