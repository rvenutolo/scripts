#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

# @description Sort all keys in the given JSON file in-place.
# @arg $1 JSON file path
function sort_json_file() {
  args::check_exactly_1_arg "$@"
  local -r json_file="$1"
  local temp_file
  temp_file="$(mktemp)"
  # expand temp_file at trap-set time (double quotes) — the local goes out of scope before EXIT fires
  # shellcheck disable=SC2064 # intentional immediate expansion
  trap "rm --force -- '${temp_file}'" EXIT
  json::sort "${json_file}" > "${temp_file}"
  files::move_no_prompt_quiet "${temp_file}" "${json_file}"
}

# @description Sort the keys of every given JSON file in place.
# @arg $@ JSON file paths
function main() {
  for file in "$@"; do
    sort_json_file "${file}"
  done
}

main "$@"
