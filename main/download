#!/usr/bin/env bash

# @description Download a URL via http::curl with linear-backoff retries, optionally writing to a given output path.
# @arg $1 url URL to download.
# @arg $2 output_file Optional output file path; when omitted, content is written to stdout.
# @stdout Downloaded content when no output file is given.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"
args::check_at_most_2_args "$@"
readonly URL="$1"
readonly OUTPUT_FILE="${2:-}"

if strings::is_not_empty "${OUTPUT_FILE}"; then
  retry::with_linear_backoff 11 15 http::curl "${URL}" --output "${OUTPUT_FILE}"
else
  retry::with_linear_backoff 11 15 http::curl "${URL}"
fi
