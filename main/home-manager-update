#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0

write_packages=1
args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-write-packages)
      write_packages=''
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done
readonly write_packages
readonly args

if strings::is_not_empty "${write_packages}"; then
  write-home-manager-packages "${args[@]}"
else
  log::log "Skipping writing packages file"
fi

nix-channel --update
nix flake update --flake "${HOME_MANAGER_DIR}"
home-manager-switch

if prompt::ny 'Run home-manager-maintenance?'; then
  home-manager-maintenance
fi
