#!/usr/bin/env bash

# @description Show the nix store closure diff between the two most recent home-manager generations.
# @noargs
# @stdout `nix store diff-closures` output between the previous and current generation.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

home-manager generations \
  | head --lines=2 \
  | tac \
  | cut --delimiter=' ' --fields=7 \
  | xargs --no-run-if-empty nix store diff-closures
