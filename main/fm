#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

disown_proc='n'
if commands::executable_exists 'xdg-open'; then
  fm='xdg-open'
  disown_proc='y'
elif commands::executable_exists 'lf'; then
  fm='lf'
elif commands::executable_exists 'ranger'; then
  fm='ranger'
elif commands::executable_exists 'fff'; then
  fm='fff'
else
  log::die "Could not find a file manager"
fi
readonly fm disown_proc

if [[ "$#" -eq 0 ]]; then
  readonly dir='.'
else
  readonly dir="$1"
fi
"${fm}" "${dir}" > '/dev/null' 2>&1 &

if [[ "${disown_proc}" == 'y' ]]; then
  disown
fi
