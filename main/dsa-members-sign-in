#!/usr/bin/env bash

# @description Reformat a Periscope members CSV into a sorted sign-in CSV (email, last_name, first_name, membership_status).
# @arg $1 input_file Path to the Periscope-exported members CSV with a header row.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_exactly_1_arg "$@"
readonly INPUT_FILE="$1"

# Download the input file from Periscope

file="members_for_sign_in_$(date +%Y%m%d_%H%M%S).csv"
readonly file

# fields: last_name, first_name, email, membership_status

python3 -c '
import csv
import sys

# Install the default signal handler.
from signal import signal, SIGPIPE, SIG_DFL

signal(SIGPIPE, SIG_DFL)

reader = csv.reader(sys.stdin)
next(reader) # skip header line
writer = csv.writer(sys.stdout)
for row in reader:
    writer.writerow([row[2], row[0], row[3], row[5]])
' < "${INPUT_FILE}" | sort >> "${file}"
