#!/usr/bin/env bash

# @description Report lines whose field count differs from the first line, for a given delimiter.
# @arg $1 input_file_or_delimiter When reading from stdin, the delimiter; otherwise the input file path.
# @arg $2 delimiter When reading from a file, the field delimiter (omit when reading from stdin).
# @stdout One line per mismatched row, with row number, actual field count, expected count, and the row.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_exactly_1_arg "$@"
  readonly DELIMITER="$1"
  awk --field-separator "${DELIMITER}" 'NR==1{nf=NF} NF!=nf{print "Line " NR " has " NF " fields (expected " nf "): " $0}'
else
  args::check_exactly_2_args "$@"
  readonly INPUT_FILE="$1"
  readonly DELIMITER="$2"
  awk --field-separator "${DELIMITER}" 'NR==1{nf=NF} NF!=nf{print "Line " NR " has " NF " fields (expected " nf "): " $0}' "${INPUT_FILE}"
fi
