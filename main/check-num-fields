#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_exactly_1_arg "$@"
  readonly DELIMITER="$1"
  awk --field-separator "${DELIMITER}" 'NR==1{nf=NF} NF!=nf{print "Line " NR " has " NF " fields (expected " nf "): " $0}'
else
  args::check_exactly_2_args "$@"
  readonly INPUT_FILE="$1"
  readonly DELIMITER="$2"
  awk --field-separator "${DELIMITER}" 'NR==1{nf=NF} NF!=nf{print "Line " NR " has " NF " fields (expected " nf "): " $0}' "${INPUT_FILE}"
fi
