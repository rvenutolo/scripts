#!/usr/bin/env bash

# @description Run the given command once per whitespace-separated item from stdin (sequential, via `xargs --max-args=1`).
# @arg $@ command Command (and any leading args) to invoke for each stdin item.
# @stdout Combined stdout from each command invocation.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"
args::check_for_stdin

# ex:
# printf '%s\n' 'foo bar' 'baz' | for-each printf '%s\n'
# runs (in sequence):
# printf '%s\n' foo
# printf '%s\n' bar
# printf '%s\n' baz
xargs --no-run-if-empty --max-args=1 "$@"
