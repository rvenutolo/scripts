#!/usr/bin/env bash

# @description Print the video resolution and path for every .mkv/.mp4 file under the current directory.
# @noargs
# @stdout One line per video file: `WIDTH;<path>` (height is dropped in favor of width-only sorting).

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

files::create_temp video_files_tmp
# shellcheck disable=SC2154 # video_files_tmp assigned by files::create_temp nameref
find . -iregex '.*\.\(mkv\|mp4\)$' -printf '%P\n' | sort > "${video_files_tmp}"

while read -r video_file; do
  resolution_info="$(
    ffprobe "${video_file}" \
      -show_entries 'stream=width,height' \
      -select_streams 'v:0' \
      -loglevel '16' \
      -output_format 'csv=s=x:p=0'
  )"
  printf '%s\n' "${resolution_info%x};${video_file}"
done < "${video_files_tmp}"
