#!/usr/bin/env bash

# @description Count regular files under each top-level subdirectory of the given path, sorted by count descending.
# @arg $1 dir Optional directory to scan; defaults to the current directory.
# @stdout `uniq -c`-style lines of count and top-level subdirectory name.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::no_args "$@"; then
  readonly dir="."
else
  readonly dir="$1"
fi

find "${dir}" -type 'f' | awk --field-separator '/' '{
  if (NF == 2) print $1;
  else if (NF > 2) print $2;
}' | sort | uniq --count | sort --numeric-sort --reverse
