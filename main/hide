#!/usr/bin/env bash

# @description Hide each given file by renaming it to start with a leading dot.
# @arg $@ paths One or more file or directory paths to hide.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

for file in "$@"; do
  dirname="$(dirname -- "${file}")"
  filename="$(basename -- "${file}")"
  target_file="${dirname}/.${filename}"
  mv -- "${file}" "${target_file}"
  log::log "${file} -> ${target_file}"
done
