#!/usr/bin/env bash

# @description Force-rebuild the fontconfig font cache via `fc-cache --force --verbose`.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

fc-cache --force --verbose
