#!/usr/bin/env bash

# @description Remove the first line from stdin (writing to stdout) or in place from the given file.
# @arg $1 file File to edit in place. Omit when piping content on stdin.
# @stdout When reading stdin, the input minus its first line.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_no_args "$@"
  tail --lines '+2'
else
  args::check_exactly_1_arg "$@"
  readonly FILE="$1"
  files::create_temp temp_file
  readonly temp_file
  cp "${FILE}" "${temp_file}"
  tail --lines '+2' "${temp_file}" > "${FILE}"
fi
