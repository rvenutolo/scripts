#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

readonly pom_file='pom.xml'
readonly env_file='.env'

# @description Evaluate a Maven expression against the current project's POM and print the result.
# Output: stdout — evaluated expression value
# @arg $1 Maven expression (e.g. "project.artifactId")
function eval_maven_expression() {
  args::check_exactly_1_arg "$@"
  local -r expression="$1"
  mvn --file "${pom_file}" help:evaluate -Dexpression="${expression}" --quiet -DforceStdout
}

# @description TODO
# @noargs
function main() {
  if ! files::exists "${pom_file}"; then
    log::die "${pom_file} is missing"
  fi
  if files::exists "${env_file}"; then
    log::die "${env_file} exists"
  fi
  local artifact_id
  artifact_id="$(eval_maven_expression 'project.artifactId')"
  local version
  version="$(eval_maven_expression 'project.version')"
  cat > "${env_file}" << EOF
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
DE_APP_ARTIFACT=${artifact_id}
DE_APP_INSTANCE=${artifact_id}
DE_APP_JOB=${artifact_id}
DE_APP_NAME=${artifact_id}
DE_APP_VERSION=${version}
DE_APP_GUID=my-${artifact_id}-guid

AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
DE_APP_BASE=.
DE_APP_CONF=conf
DE_APP_OUTPUT=output
DE_ENV=dev
EOF
}

main "$@"
