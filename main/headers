#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_at_most_1_arg "$@"
  readonly DELIMITER_ARG="${1:-}"
  header_line="$(text::first_line)"
  if strings::is_not_empty "${DELIMITER_ARG}"; then
    readonly delimiter="${DELIMITER_ARG}"
  fi
else
  args::check_at_least_1_arg "$@"
  args::check_at_most_2_args "$@"
  readonly INPUT_FILE="$1"
  readonly DELIMITER_ARG="${2:-}"
  header_line="$(text::first_line "${INPUT_FILE}")"
  if strings::is_not_empty "${DELIMITER_ARG}"; then
    readonly delimiter="${DELIMITER_ARG}"
  fi
fi
readonly header_line

if strings::is_empty "${delimiter+x}"; then
  if grep::contains_exactly ';' <<< "${header_line}"; then
    readonly delimiter=';'
  elif grep::contains_exactly ',' <<< "${header_line}"; then
    readonly delimiter=','
  elif grep::contains_exactly $'\t' <<< "${header_line}"; then
    readonly delimiter=$'\t'
  elif grep::contains_exactly '|' <<< "${header_line}"; then
    readonly delimiter='|'
  elif grep::contains_exactly ':' <<< "${header_line}"; then
    readonly delimiter=':'
  else
    readonly delimiter=','
  fi
fi

tr "${delimiter}" '\n' <<< "${header_line}" | cat --number
