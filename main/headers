#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
enable_err_trap
require_bash_version 4 0

if stdin_exists; then
  check_at_most_1_arg "$@"
  header_line="$(first_line)" || exit 1
  if is_not_empty "${1:-}"; then
    readonly delimiter="$1"
  fi
else
  check_at_least_1_arg "$@"
  check_at_most_2_args "$@"
  header_line="$(first_line "$1")" || exit 1
  if is_not_empty "${2:-}"; then
    readonly delimiter="$2"
  fi
fi
readonly header_line

if is_empty "${delimiter+x}"; then
  if contains_exactly ';' <<< "${header_line}"; then
    readonly delimiter=';'
  elif contains_exactly ',' <<< "${header_line}"; then
    readonly delimiter=','
  elif contains_exactly $'\t' <<< "${header_line}"; then
    readonly delimiter=$'\t'
  elif contains_exactly '|' <<< "${header_line}"; then
    readonly delimiter='|'
  elif contains_exactly ':' <<< "${header_line}"; then
    readonly delimiter=':'
  else
    readonly delimiter=','
  fi
fi

tr "${delimiter}" '\n' <<< "${header_line}" | cat --number
