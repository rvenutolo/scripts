#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
enable_err_trap

if stdin_exists; then
  check_no_args "$@"
  sort | uniq --count | sort --numeric-sort --reverse
else
  check_exactly_1_arg "$@"
  sort "$1" | uniq --count | sort --numeric-sort --reverse
fi
