#!/usr/bin/env bash

# @description Count occurrences of each distinct line in a file or stdin, sorted by descending count.
# @arg $1 input_file Optional path to the input file; when omitted, input is read from stdin.
# @stdout `count line` pairs, sorted by descending count.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_no_args "$@"
  sort | uniq --count | sort --numeric-sort --reverse
else
  args::check_exactly_1_arg "$@"
  readonly FILE="$1"
  sort "${FILE}" | uniq --count | sort --numeric-sort --reverse
fi
