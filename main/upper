#!/usr/bin/env bash

# @description Uppercase text from stdin, or rename one or more files to their uppercase basenames.
# @arg $@ files Optional file paths to rename to uppercase; when omitted reads from stdin and writes uppercase to stdout.
# @stdout When stdin is provided, the uppercased text.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_no_args "$@"
  tr '[:lower:]' '[:upper:]'
else
  args::check_at_least_1_arg "$@"
  for file in "$@"; do
    dirname="$(dirname -- "${file}")"
    filename="$(basename -- "${file}")"
    lower_filename="$(printf '%s\n' "${filename}" | tr '[:lower:]' '[:upper:]')"
    target_file="${dirname}/${lower_filename}"
    if [[ "${lower_filename}" != "${filename}" ]]; then
      mv -- "${file}" "${target_file}"
      log::log "${file} -> ${target_file}"
    else
      log::log "${file} not renamed"
    fi
  done
fi
