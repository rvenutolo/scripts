#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
enable_err_trap
check_at_least_1_arg "$@"
check_for_stdin

# printf '%s\n' 'foo bar' 'baz' | for-each-parallel printf '%s\n'
# runs (in parallel):
# printf '%s\n' foo
# printf '%s\n' bar
# printf '%s\n' baz
xargs --no-run-if-empty --max-procs="$(nproc)" --max-args=1 "$@"
