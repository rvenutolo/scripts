#!/usr/bin/env bash

# @description Run the given command once per whitespace-separated item from stdin in parallel across all CPU cores.
# @arg $@ command Command (and any leading args) to invoke for each stdin item.
# @stdout Combined (interleaved) stdout from each command invocation.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"
args::check_for_stdin

# printf '%s\n' 'foo bar' 'baz' | for-each-parallel printf '%s\n'
# runs (in parallel):
# printf '%s\n' foo
# printf '%s\n' bar
# printf '%s\n' baz
xargs --no-run-if-empty --max-procs="$(nproc)" --max-args=1 "$@"
