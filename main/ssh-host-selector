#!/usr/bin/env bash

# @description Pick a host from `~/.ssh/config.private` via `fzf` and `ssh` to it.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

ssh_host="$(
  grep '^Host' ~/.ssh/config.private \
    | grep --invert-match '[?*]' \
    | cut --delimiter ' ' --fields 2 \
    | sort \
    | fzf --height=20 --exact --layout=reverse
)"
readonly ssh_host

ssh "${ssh_host}"
