#!/usr/bin/env bash

# @description Run `sync-flatpaks`, `sync-appimages`, and `home-manager-update` for each tool that is installed.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

if commands::executable_exists 'flatpak'; then
  sync-flatpaks
fi

if commands::executable_exists 'appman'; then
  sync-appimages
fi

if commands::executable_exists 'home-manager'; then
  home-manager-update
fi
