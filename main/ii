#!/usr/bin/env bash

# @description Print a quick host info summary (hostname, kernel, logged-in users, date, uptime, memory).
# @noargs
# @stdout Multi-section host info report.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

printf '\nYou are logged on %s\n' "$(hostname)"
printf '\nAdditional information: \n'
uname --all
printf '\nUsers logged on: \n'
w --no-header
printf '\nCurrent date: \n'
date
printf '\nMachine stats: \n'
uptime
printf '\nMemory stats: \n'
free
