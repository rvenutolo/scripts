#!/usr/bin/env bash

# @description Reconcile installed user Flatpaks with the universal package list — install missing apps, prompt to remove extras, prune unused runtimes, update everything, and apply XDG overrides for Chrome.
# @arg $@ filters Optional filter args forwarded to `packages::get_universal` to scope the package list.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
# pass-through: any arg count valid ($@ forwarded as filter args to packages::get_universal)

commands::assert_executable_exists 'flatpak'

files::create_temp pkg_list_file
# shellcheck disable=SC2154 # pkg_list_file assigned by files::create_temp via nameref
packages::get_universal 'flatpak' "$@" | sort > "${pkg_list_file}"
mapfile -t flatpaks_from_package_list < "${pkg_list_file}"
readonly flatpaks_from_package_list

files::create_temp installed_file
# shellcheck disable=SC2154 # installed_file assigned by files::create_temp via nameref
flatpak list --user --app --columns application | sort > "${installed_file}"
mapfile -t flatpaks_installed < "${installed_file}"
readonly flatpaks_installed

files::create_temp diff_file
# shellcheck disable=SC2154 # diff_file assigned by files::create_temp via nameref
arrays::diff flatpaks_from_package_list flatpaks_installed > "${diff_file}"
mapfile -t flatpaks_to_install < "${diff_file}"
readonly flatpaks_to_install

files::create_temp pkg_list_sorted_file
files::create_temp installed_sorted_file
files::create_temp remove_file
# shellcheck disable=SC2154 # pkg_list_sorted_file assigned by files::create_temp via nameref
arrays::to_lines "${flatpaks_from_package_list[@]}" > "${pkg_list_sorted_file}"
# shellcheck disable=SC2154 # installed_sorted_file assigned by files::create_temp via nameref
arrays::to_lines "${flatpaks_installed[@]}" > "${installed_sorted_file}"
# shellcheck disable=SC2154 # remove_file assigned by files::create_temp via nameref
comm -13 "${pkg_list_sorted_file}" "${installed_sorted_file}" > "${remove_file}"
mapfile -t flatpaks_to_remove < "${remove_file}"
readonly flatpaks_to_remove

if ((${#flatpaks_to_install[@]})) && prompt::yn 'Install missing Flatpak packages?'; then
  log::log 'Installing missing Flatpak packages'
  arrays::to_lines "${flatpaks_to_install[@]}" | xargs --no-run-if-empty --max-args=100 flatpak install --user --noninteractive
  log::log 'Installed missing Flatpak packages'
fi

for flatpak_to_remove in "${flatpaks_to_remove[@]}"; do
  flatpak_name="$(
    flatpak list --user --app --columns name --columns application \
      | awk --field-separator $'\t' --assign "to_remove=${flatpak_to_remove}" '$2 == to_remove { print $1 }'
  )"
  if prompt::yn "Remove ${flatpak_name} (${flatpak_to_remove})?"; then
    log::log "Removing ${flatpak_name} (${flatpak_to_remove})"
    flatpak remove --user --noninteractive "${flatpak_to_remove}"
    log::log "Removed ${flatpak_name} (${flatpak_to_remove})"
  fi
done

log::log 'Removing unused Flatpak runtimes'
flatpak uninstall --user --noninteractive --unused
log::log 'Removed unused Flatpak runtimes'

log::log 'Updating all Flatpak packages'
flatpak update --user --noninteractive
log::log 'Updated all Flatpak packages'

if flatpak list --user --app | grep::contains_word_ignore_case 'com.google.chrome'; then
  flatpak override --user \
    --filesystem="${XDG_DATA_HOME}/applications:create" \
    --filesystem="${XDG_DATA_HOME}/icons:create" \
    'com.google.Chrome'
fi
