#!/usr/bin/env bash

# @description Print audio-track info for every .mkv/.mp4 file under the current directory that lacks an English audio track.
# @arg $1 mode Optional literal `debug` to log each video filename as it is probed.
# @stdout For each matching video: the relative path, one line per audio stream, and a `---------` separator.
# @exitcode 1 The optional argument is present but not the literal string `debug`.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::has_num_args 1 "$@"; then
  readonly MODE="$1"
  if [[ "${MODE}" == 'debug' ]]; then
    readonly debug='true'
  else
    log::die "Expected 1 arg: 'debug'"
  fi
else
  readonly debug='false'
fi

files::create_temp video_files_tmp
# shellcheck disable=SC2154 # video_files_tmp assigned by files::create_temp nameref
find . -iregex '.*\.\(mkv\|mp4\)$' -printf '%P\n' | sort > "${video_files_tmp}"

while read -r video_file; do
  if [[ "${debug}" == 'true' ]]; then
    log::log "${video_file}"
  fi
  audio_info="$(
    ffprobe "${video_file}" \
      -show_entries 'stream=index,codec_name,channel_layout:stream_tags=language' \
      -select_streams 'a' \
      -loglevel '16' \
      -output_format 'compact=p=0:nk=1' \
      | awk --field-separator '|' '{ print $1 " | " $4 " | " $2 " | " $3 }'
  )"
  if grep --quiet --invert-match --fixed-strings '| eng |' <<< "${audio_info}"; then
    printf '%s\n' "${video_file}"
    printf '%s\n' "${audio_info}"
    printf '%s\n' '---------'
  fi
done < "${video_files_tmp}"
