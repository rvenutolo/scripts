#!/usr/bin/env bash

# @description Visualize whitespace in stdin or a file by replacing spaces, tabs, CR, and LF with printable glyphs.
# @arg $1 file Optional path to read from; reads stdin when omitted.
# @stdout The input with whitespace characters replaced by middle-dot, halfwidth arrow, section sign, and pilcrow.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

# SP  ' '  0x20 = · U+00B7 Middle Dot
# TAB '\t' 0x09 = ￫ U+FFEB Halfwidth Rightwards Arrow
# CR  '\r' 0x0D = § U+00A7 Section Sign (⏎ U+23CE also works fine)
# LF  '\n' 0x0A = ¶ U+00B6 Pilcrow Sign (was "Paragraph Sign")
if args::stdin_exists; then
  args::check_no_args "$@"
  sed 's/ /·/g;s/\t/￫/g;s/\r/§/g;s/$/¶/g'
else
  args::check_exactly_1_arg "$@"
  readonly FILE="$1"
  sed 's/ /·/g;s/\t/￫/g;s/\r/§/g;s/$/¶/g' "${FILE}"
fi
