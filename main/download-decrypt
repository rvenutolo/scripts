#!/usr/bin/env bash

# @description Download an age-encrypted file from a URL and decrypt it using AGE_PRIVATE_KEY_FILE.
# @arg $1 url URL of the age-encrypted file to download.
# @arg $2 output_file Optional decrypted output file path; when omitted, plaintext goes to stdout.
# @stdout Decrypted content when no output file is given.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_at_least_1_arg "$@"
args::check_at_most_2_args "$@"
readonly URL="$1"
readonly OUTPUT_FILE="${2:-}"

temp_file="$(downloads::download_to_temp_file "${URL}")"
readonly temp_file
if strings::is_not_empty "${OUTPUT_FILE}"; then
  age --decrypt --identity "${AGE_PRIVATE_KEY_FILE}" --output "${OUTPUT_FILE}" "${temp_file}"
else
  age --decrypt --identity "${AGE_PRIVATE_KEY_FILE}" "${temp_file}"
fi
