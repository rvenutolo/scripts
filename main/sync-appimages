#!/usr/bin/env bash

# @description Reconcile installed AppImages (`appman`) with the universal package list — install missing ones, prompt to remove extras, and update all installed packages.
# @arg $@ filters Optional filter args forwarded to `packages::get_universal` to scope the package list.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
# pass-through: any arg count valid ($@ forwarded as filter args to packages::get_universal)

commands::assert_executable_exists 'appman'

files::create_temp pkg_list_file
# shellcheck disable=SC2154 # pkg_list_file assigned by files::create_temp via nameref
packages::get_universal 'appimage' "$@" | sort > "${pkg_list_file}"
mapfile -t appimages_from_package_list < "${pkg_list_file}"
readonly appimages_from_package_list

files::create_temp installed_file
# shellcheck disable=SC2154 # installed_file assigned by files::create_temp via nameref
find "${XDG_DATA_HOME}/appman/" \
  -mindepth 1 -maxdepth 1 -type 'd' ! -name 'appman' -printf '%f\n' \
  | sort > "${installed_file}"
mapfile -t appimages_installed < "${installed_file}"
readonly appimages_installed

files::create_temp diff_file
# shellcheck disable=SC2154 # diff_file assigned by files::create_temp via nameref
arrays::diff appimages_from_package_list appimages_installed > "${diff_file}"
mapfile -t appimages_to_install < "${diff_file}"
readonly appimages_to_install

files::create_temp pkg_list_sorted_file
files::create_temp installed_sorted_file
files::create_temp remove_file
# shellcheck disable=SC2154 # pkg_list_sorted_file assigned by files::create_temp via nameref
arrays::to_lines "${appimages_from_package_list[@]}" > "${pkg_list_sorted_file}"
# shellcheck disable=SC2154 # installed_sorted_file assigned by files::create_temp via nameref
arrays::to_lines "${appimages_installed[@]}" > "${installed_sorted_file}"
# shellcheck disable=SC2154 # remove_file assigned by files::create_temp via nameref
comm -13 "${pkg_list_sorted_file}" "${installed_sorted_file}" > "${remove_file}"
mapfile -t appimages_to_remove < "${remove_file}"
readonly appimages_to_remove

if (("${#appimages_to_install[@]}")) && prompt::yn 'Install missing AppImage packages?'; then
  log::log 'Installing missing AppImage packages'
  arrays::to_lines "${appimages_to_install[@]}" | xargs --no-run-if-empty --max-args=1 appman install
  log::log 'Installed missing AppImage packages'
fi

for appimage_to_remove in "${appimages_to_remove[@]}"; do
  if prompt::yn "Remove ${appimage_to_remove}?"; then
    log::log "Removing ${appimage_to_remove}"
    # appman has no long form for -R (remove); short flag is the only option
    # I don't know why remove operation exit code is non-zero
    appman -R "${appimage_to_remove}" || true
    log::log "Removed ${appimage_to_remove}"
  fi
done

log::log 'Updating all AppImage packages'
appman update
log::log 'Updated all AppImage packages'
