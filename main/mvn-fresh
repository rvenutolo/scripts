#!/usr/bin/env bash

# @description Run `mvn-sources`, then `mvn clean` with the given goals. `clean` is always
#   prepended automatically, so callers must NOT pass `clean` themselves.
# @arg $@ goals forwarded to `mvn clean`
# @example
#   mvn-fresh install
#   mvn-fresh verify -DskipTests

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@" # pass-through: forwards goals to mvn clean

mvn-sources
mvn clean "$@"
