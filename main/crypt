#!/usr/bin/env bash

# @description Encrypt each given file with `age` using AGE_PUBLIC_KEY and write the armored ciphertext to CRYPT_DIR.
# @arg $@ files One or more file paths to encrypt.
# @exitcode 1 A given path is not a regular file.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

for file in "$@"; do
  if files::exists "${file}"; then
    target_file="${CRYPT_DIR}/$(basename -- "${file}")"
    log::log "Encrypting: ${file} to: ${target_file}"
    age --encrypt --recipient="${AGE_PUBLIC_KEY}" --armor --output="${target_file}" -- "${file}"
  else
    log::die "${file} is not file"
  fi
done
