#!/usr/bin/env bash

# @description Open a Google search for the given query in the default browser via xdg-open.
# @arg $@ query One or more search terms; joined with `%20` separators.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

log::log "Googling: $*"
readonly search="${*// /%20}"
misc::exec_gui xdg-open "https://www.google.com/search?q=${search}"
