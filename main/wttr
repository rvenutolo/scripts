#!/usr/bin/env bash

# @description Fetch and print the wttr.in weather report for the given city (defaults to $WTTR_CITY).
# @arg $1 city Optional city name; defaults to $WTTR_CITY when omitted.
# @stdout The wttr.in ANSI-formatted weather report.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::no_args "$@"; then
  readonly CITY="${WTTR_CITY}"
else
  readonly CITY="$1"
fi
downloads::download_and_cat "wttr.in/${CITY}"
