#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::no_args "$@"; then
  readonly CITY="${WTTR_CITY}"
else
  readonly CITY="$1"
fi
downloads::download_and_cat "wttr.in/${CITY}"
