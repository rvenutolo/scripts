#!/usr/bin/env bash

# @description Wrap `mvn`, preferring the project's `./mvnw` wrapper when one is found in the current directory or an ancestor.
# @arg $@ args Arguments forwarded verbatim to `mvnw` or `mvn`.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

# remove this dir from the path so executing `mvn` doesn't execute this script
path::remove "$(misc::this_script_dir)"

dir="${PWD}"
project_root="${PWD}"
while [[ "${dir}" != / ]]; do
  if files::exists "${dir}/pom.xml" || files::exists "${dir}/mvnw"; then
    readonly project_root="${dir}"
    break
  fi
  dir="$(dirname -- "${dir}")"
done
readonly project_root

if files::is_executable "${project_root}/mvnw"; then
  log::log 'Executing mvnw instead of mvn'
  exec "${project_root}/mvnw" "$@"
else
  exec mvn "$@"
fi
