#!/usr/bin/env bash

# @description Wrap `rsync` with a standard backup flag set (`--archive --human-readable --executability --stats --progress`).
# @arg $@ args Source/destination paths and any additional `rsync` options to forward.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_2_args "$@"

# --archive : --recursive --links --perms --times --group --owner --device --specials
#             --recursive recurse into directories
#             --links copy symlinks as symlinks
#             --perms preserve permissions
#             --times preserve modification times
#             --group preserve group
#             --owner preserver owner (super-user only)
#             --device preserve device files (super-user only)
#             --specials preserve special files
# --human-readable : output numbers in a human-readable format
# --executability : preserve executability
# --stats: give some file-transfer stats
# --progress: show progress during transfer
rsync \
  --archive \
  --human-readable \
  --executability \
  --stats \
  --progress \
  "$@"
