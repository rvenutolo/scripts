#!/usr/bin/env bash

# @description Remove all dangling (untagged) Podman images.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

images="$(podman images --all --filter=dangling=true --quiet)"
readonly images
if strings::is_not_empty "${images}"; then
  podman rmi "${images}"
fi
