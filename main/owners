#!/usr/bin/env bash

# @description Print the unique `user:group` ownership pairs found under the given directory (or the current directory).
# @arg $1 dir Optional directory to scan. Defaults to the current directory when omitted.
# @stdout Sorted list of unique `user:group` pairs, one per line.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::no_args "$@"; then
  readonly DIR='.'
else
  readonly DIR="$1"
fi

find "${DIR}" -printf '%u:%g\n' | sort --field-separator=':' --unique
