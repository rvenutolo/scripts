#!/usr/bin/env bash

# @description Print per-track audio info (index, language, codec, channel layout) for every .mkv/.mp4 file under the current directory.
# @noargs
# @stdout For each video file: the relative path, one line per audio stream, and a `---------` separator.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

files::create_temp video_files_tmp
# shellcheck disable=SC2154 # video_files_tmp assigned by files::create_temp nameref
find . -iregex '.*\.\(mkv\|mp4\)$' -printf '%P\n' | sort > "${video_files_tmp}"

while read -r video_file; do
  printf '%s\n' "${video_file}"
  audio_info="$(
    ffprobe "${video_file}" \
      -show_entries 'stream=index,codec_name,channel_layout:stream_tags=language' \
      -select_streams 'a' \
      -loglevel '16' \
      -output_format 'compact=p=0:nk=1' \
      | awk --field-separator '|' '{ print $1 " | " $4 " | " $2 " | " $3 }'
  )"
  printf '%s\n' "${audio_info}"
  printf '%s\n' '---------'
done < "${video_files_tmp}"
