#!/usr/bin/env bash

# @description After confirmation, GPG-sign every commit in the current repository via `git filter-branch --commit-filter`, regardless of author.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

if prompt::ny 'This will sign ALL commits (without checking commit authors). Continue?'; then
  FILTER_BRANCH_SQUELCH_WARNING='1' git filter-branch --force --commit-filter 'git commit-tree --gpg-sign "$@";'
fi

log::log "Check the log, then push changes with: git push --force --tags origin 'refs/heads/*'"
