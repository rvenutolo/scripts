#!/usr/bin/env bash

# @description Download and age-decrypt the age key, the SSH keypair, and any other keys from the rvenutolo/crypt repo into ${KEYS_DIR}, prompting before downloading extras.
# @noargs
# @exitcode 1 A downloaded key file is empty.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

readonly keys_repo_url='https://raw.githubusercontent.com/rvenutolo/crypt/main/keys'
dirs::create "${KEYS_DIR}"

if ! files::exists "${AGE_PRIVATE_KEY_FILE}"; then
  log::log "Downloading: ${AGE_PRIVATE_KEY_FILE}"
  temp_file="$(downloads::download_to_temp_file "${keys_repo_url}/age.key")"
  if files::is_non_empty "${temp_file}"; then
    log::log "Decrypting: ${AGE_PRIVATE_KEY_FILE}"
    until age --decrypt --output "${AGE_PRIVATE_KEY_FILE}" "${temp_file}"; do :; done
  else
    log::die "age key file content is empty"
  fi
fi

for filename in 'id_ed25519' 'id_ed25519.pub'; do
  key_file="${KEYS_DIR}/${filename}"
  if ! files::exists "${key_file}"; then
    log::log "Downloading: ${key_file}"
    temp_file="$(downloads::download_to_temp_file "${keys_repo_url}/${filename}")"
    if files::is_non_empty "${temp_file}"; then
      log::log "Decrypting: ${key_file}"
      age --decrypt --identity "${AGE_PRIVATE_KEY_FILE}" --output "${key_file}" "${temp_file}"
    else
      log::die "${filename} content is empty"
    fi
  fi
done

files::create_temp urls_file
# shellcheck disable=SC2154 # urls_file assigned by files::create_temp via nameref
downloads::download_and_cat 'https://api.github.com/repos/rvenutolo/crypt/contents/keys' \
  | jq --raw-output '.[].download_url' > "${urls_file}"
mapfile -t urls < "${urls_file}"
for url in "${urls[@]}"; do
  filename="$(basename "${url}")"
  if [[ "${filename}" == 'age.key' || "${filename}" == 'id_ed25519' || "${filename}" == 'id_ed25519.pub' ]]; then
    continue
  fi
  key_file="${KEYS_DIR}/${filename}"
  if ! files::exists "${key_file}" && prompt::ny "Download ${filename}?"; then
    log::log "Downloading: ${filename}"
    temp_file="$(downloads::download_to_temp_file "${keys_repo_url}/${filename}")"
    if files::is_non_empty "${temp_file}"; then
      log::log "Decrypting: ${key_file}"
      age --decrypt --identity "${AGE_PRIVATE_KEY_FILE}" --output "${key_file}" "${temp_file}"
    else
      log::die "${filename} content is empty"
    fi
  fi
done

find "${KEYS_DIR}" -type 'd' -exec chmod 700 {} \;
find "${KEYS_DIR}" -type 'f' -exec chmod 600 {} \;
