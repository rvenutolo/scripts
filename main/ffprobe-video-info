#!/usr/bin/env bash

# @description Print width, height, codec, size, and path for every .mkv/.mp4 file under the current directory.
# @noargs
# @stdout One pipe-delimited line per video file: width | height | codec | size_gb | dirname | basename.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

files::create_temp video_files_tmp
# shellcheck disable=SC2154 # video_files_tmp assigned by files::create_temp nameref
find . -iregex '.*\.\(mkv\|mp4\)$' -printf '%P\n' | sort > "${video_files_tmp}"

while read -r video_file; do
  video_info="$(
    ffprobe "${video_file}" \
      -show_entries 'stream=codec_name,width,height' \
      -select_streams 'v:0' \
      -loglevel '16' \
      -output_format 'compact=p=0:nk=1' \
      | awk --field-separator '|' '{ print $2 " | " $3 " | " $1 }'
  )"
  size_gb="$(files::size_gb "${video_file}")"
  printf '%s\n' "${video_info} | ${size_gb}G | $(dirname "${video_file}") | $(basename "${video_file}")"
done < "${video_files_tmp}"
