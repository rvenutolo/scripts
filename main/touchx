#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

for file in "$@"; do
  if [[ -e "${file}" ]] && ! files::exists "${file}"; then
    log::log "${file} is NOT a file"
  else
    touch "${file}"
    chmod +x "${file}"
  fi
done
