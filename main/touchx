#!/usr/bin/env bash

# @description `touch` each path and mark it executable. Paths that already exist as non-regular-files are skipped with a warning.
# @arg $@ files One or more file paths to create (if needed) and chmod +x.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

for file in "$@"; do
  if files::any_exists "${file}" && ! files::exists "${file}"; then
    log::log "${file} is NOT a file"
  else
    touch "${file}"
    chmod +x "${file}"
  fi
done
