#!/usr/bin/env bash

# @description Download source and Javadoc jars for every `pom.xml` found under the current directory.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

# @description Download sources and Javadoc jars for all dependencies declared in the given POM.
# @arg $1 pom file path
function get_sources() {
  args::check_exactly_1_arg "$@"
  local -r pom="$1"
  mvn --file "${pom}" \
    org.apache.maven.plugins:maven-dependency-plugin:resolve-sources \
    org.apache.maven.plugins:maven-dependency-plugin:resolve \
    -Dclassifier=javadoc
}

# @description Resolve sources and Javadoc jars for every pom.xml found under the cwd.
# @noargs
function main() {
  local pom_files
  pom_files="$(mvn::list_pom_files)"
  while IFS='' read -r pom_file; do
    get_sources "${pom_file}"
  done <<< "${pom_files}"
}

main "$@"
