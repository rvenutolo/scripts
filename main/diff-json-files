#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_exactly_2_args "$@"

if ! files::exists "$1"; then
  log::die "File does not exist: $1"
fi

if ! files::exists "$2"; then
  log::die "File does not exist: $2"
fi

diff --color=always --report-identical-files --unified --text \
  <(jq --sort-keys . "$1") \
  <(jq --sort-keys . "$2") \
  | text::skip_first_lines 3
