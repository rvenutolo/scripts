#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_exactly_2_args "$@"

files::assert_exists "$1"
files::assert_exists "$2"

diff --color=always --report-identical-files --unified --text \
  <(jq --sort-keys . "$1") \
  <(jq --sort-keys . "$2") \
  | text::skip_first_lines 3
