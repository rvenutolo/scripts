#!/usr/bin/env bash

# @description Diff two JSON files semantically by sorting keys with jq first, then producing a colored unified diff.
# @arg $1 file_a Path to the first JSON file.
# @arg $2 file_b Path to the second JSON file.
# @stdout Colored unified diff (or an "identical" line) with the diff header trimmed off.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_exactly_2_args "$@"
readonly FILE_A="$1"
readonly FILE_B="$2"

files::assert_exists "${FILE_A}"
files::assert_exists "${FILE_B}"

files::create_temp sorted_a_file
files::create_temp sorted_b_file
# shellcheck disable=SC2154 # sorted_a_file assigned by files::create_temp via nameref
jq --sort-keys . "${FILE_A}" > "${sorted_a_file}"
# shellcheck disable=SC2154 # sorted_b_file assigned by files::create_temp via nameref
jq --sort-keys . "${FILE_B}" > "${sorted_b_file}"
diff --color=always --report-identical-files --unified --text \
  "${sorted_a_file}" \
  "${sorted_b_file}" \
  | text::skip_first_lines 3
