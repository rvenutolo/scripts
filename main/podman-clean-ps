#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

containers="$(podman ps --filter=status=exited --filter=status=created --quiet)"
readonly containers
if strings::is_not_empty "${containers}"; then
  podman rm "${containers}"
fi
