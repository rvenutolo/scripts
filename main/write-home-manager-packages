#!/usr/bin/env bash

# @description Insert one or more package names into the home-manager `stable.nix` and `unstable.nix` package lists.
# @arg $@ packages One or more package names to add (forwarded to `packages::get_universal`).

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0

# @description Create a minimal Nix packages file skeleton if the file does not already exist.
# @arg $1 packages file path
# @arg $2 package set ('nixpkgs' or 'nixpkgs-unstable')
function write_packages_file_skeleton() {
  args::check_exactly_2_args "$@"
  local -r packages_file="$1"
  local -r package_type="$2"
  if files::exists "${packages_file}"; then
    return 0
  fi
  dirs::create "$(dirname "${packages_file}")"
  if [[ "${package_type}" == 'nixpkgs' ]]; then
    cat > "${packages_file}" << 'EOF'
{ pkgs, ... }:
{
  home.packages = with pkgs; [
  ];
}
EOF
  elif [[ "${package_type}" == 'nixpkgs-unstable' ]]; then
    cat > "${packages_file}" << 'EOF'
{ pkgs-unstable, ... }:
{
  home.packages = with pkgs-unstable; [
  ];
}
EOF
  else
    log::die "Unexpected package type: '${package_type}'"
  fi
}

# @description Print the line number of the first line in a file matching the given regex.
# Output: stdout — line number as a plain integer
# @arg $1 packages file path
# @arg $2 regex to match (e.g. '\[' or ']')
function get_line_number() {
  args::check_exactly_2_args "$@"
  local -r packages_file="$1"
  local -r regex="$2"
  grep --line-number --max-count=1 "${regex}" "${packages_file}" | cut --delimiter=':' --fields=1
}

# @description Write the current package list into the packages array inside a Nix packages file.
# Creates the file skeleton if it does not exist. Extra args are forwarded to packages::get_universal.
# $3+ = extra arguments forwarded to packages::get_universal (e.g. --ignore, --quiet)
# @arg $1 packages file path
# @arg $2 package set ('nixpkgs' or 'nixpkgs-unstable')
function write_packages_into() {
  args::check_at_least_2_args "$@"
  local -r packages_file="$1"
  local -r package_type="$2"
  shift 2
  local temp_file
  # shellcheck disable=SC2034 # temp_file set via nameref inside files::create_temp
  files::create_temp temp_file
  write_packages_file_skeleton "${packages_file}" "${package_type}"
  {
    awk \
      "NR <= $(get_line_number "${packages_file}" '\[')" \
      "${packages_file}"
    packages::get_universal "${package_type}" "$@" | sed 's/^/    /'
    awk \
      "NR >= $(get_line_number "${packages_file}" ']')" \
      "${packages_file}"
  } >> "${temp_file}"
  files::move_no_prompt_quiet "${temp_file}" "${packages_file}"
}

# @description Insert each given package name into the stable.nix and unstable.nix home-manager package lists.
# @arg $@ package names to insert
function main() {
  write_packages_into "${HOME_MANAGER_PACKAGES_DIR}/stable.nix" 'nixpkgs' "$@"
  write_packages_into "${HOME_MANAGER_PACKAGES_DIR}/unstable.nix" 'nixpkgs-unstable' "$@"
}

main "$@"
