#!/usr/bin/env bash

# @description Remove duplicate lines from stdin or a file via awk, preserving original order (unlike `sort --unique`).
# @arg $1 file Optional path to read from; reads stdin when omitted.
# @stdout Input lines with duplicates removed, in original order.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_no_args "$@"
  awk '!x[$0]++'
else
  args::check_exactly_1_arg "$@"
  readonly FILE="$1"
  awk '!x[$0]++' "${FILE}"
fi
