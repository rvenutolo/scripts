#!/usr/bin/env bash

# @description Run the `claude` CLI with CLAUDE_CONFIG_DIR forced to the personal profile, overriding any existing value.
# @arg $@ args Optional arguments forwarded verbatim to claude.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
# pass-through: any arg count valid (forwarded to claude)

# remove this dir from the path so executing `claude` doesn't run the `claude` script
path::remove "$(misc::this_script_dir)"

CLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME}/claude/personal" exec claude "$@"
