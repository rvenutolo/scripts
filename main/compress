#!/usr/bin/env bash

# @description Compress one or more files/directories into an archive, dispatching by the output filename extension.
# @arg $1 file Output archive path; extension selects the compressor (.tar*, .bz2, .gz, .lzma, .rar, .xz, .zip, .7z).
# @arg $@ inputs Files/directories to add to the archive.
# @exitcode 1 Output filename has an unrecognized extension.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_at_least_1_arg "$@"

readonly FILE="$1"
shift
case "${FILE}" in
  *.tar | *.tar.* | *.tbz2 | *.tgz) tar --create --verbose --auto-compress --file "${FILE}" "$@" ;;
  *.bz2) bzip2 --verbose "${FILE}" "$@" ;;
  *.gz) gzip --verbose "${FILE}" "$@" ;;
  *.lzma) xz --verbose --format=lzma "${FILE}" "$@" ;;
  *.rar) rar a "${FILE}" "$@" ;;
  *.xz) xz --verbose "${FILE}" "$@" ;;
  *.zip) zip --verbose "${FILE}" "$@" ;;
  *.7z) 7z a "${FILE}" "$@" ;;
  *) log::die "Filetype not recognized: ${FILE}" ;;
esac
log::log "compressed '${FILE}'"
