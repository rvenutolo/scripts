#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_exactly_1_arg "$@"

if ! files::exists "$1"; then
  log::die "$1 does not exist"
fi

if ! files::is_readable "$1"; then
  log::die "$1 is not readable"
fi

printf '%s\n' "----------"
printf '%s\n' "$1"
printf '%s\n' "----------"
ls --format=long "$1"
file "$1"
