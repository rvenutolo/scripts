#!/usr/bin/env bash

# @description Print a formatted info dump (long ls listing and file(1) type) for the given file.
# @arg $1 input_file Path to the file to inspect.
# @stdout Header banner, then `ls --format=long` output, then `file` type output.
# @exitcode 1 Input file does not exist or is not readable.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_exactly_1_arg "$@"
readonly INPUT_FILE="$1"

files::assert_exists "${INPUT_FILE}"

if ! files::is_readable "${INPUT_FILE}"; then
  log::die "${INPUT_FILE} is not readable"
fi

printf '%s\n' "----------"
printf '%s\n' "${INPUT_FILE}"
printf '%s\n' "----------"
ls --format=long "${INPUT_FILE}"
file "${INPUT_FILE}"
