#!/usr/bin/env bash

# @description Print the Build-Jdk-Spec line from a JAR file's META-INF/MANIFEST.MF.
# @arg $1 jar_file Path to the JAR file to inspect.
# @stdout The matching `Build-Jdk-Spec:` manifest line.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_exactly_1_arg "$@"

unzip -p "$1" 'META-INF/MANIFEST.MF' | grep --fixed-strings 'Build-Jdk-Spec'
