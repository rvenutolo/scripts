#!/usr/bin/env bash

# @description Show the status of every system-level and user-level systemd timer unit.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

systemctl status '*timer' --no-pager
systemctl status --user '*timer' --no-pager
