#!/usr/bin/env bash

# @description Pretty-print files (or stdin) with syntax highlighting; Markdown files are rendered via `glow`.
# @arg $@ files One or more files to pretty-print. Omit when piping content on stdin.
# @stdout Syntax-highlighted file contents.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0

if args::stdin_exists; then
  args::check_no_args "$@"
  highlight --out-format=ansi --force
else
  args::check_at_least_1_arg "$@"
  for file in "$@"; do
    case "${file}" in
      *.md) glow "${file}" ;;
      *) highlight --out-format=ansi --force "${file}" ;;
    esac
  done
fi
