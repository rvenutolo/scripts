#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 3

shell_scripts::assert_paths_exist "$@"

mapfile -t candidates < <(shell_scripts::find "$@")
if [[ "${#candidates[@]}" -eq 0 ]]; then
  exit 0
fi

files=()
shell_scripts::filter files "${candidates[@]}"
if [[ "${#files[@]}" -eq 0 ]]; then
  exit 0
fi

rc=0
shfmt --list --indent=2 --case-indent --binary-next-line --space-redirects --diff "${files[@]}" || rc=1
shellcheck "${files[@]}" || rc=1
exit "${rc}"
