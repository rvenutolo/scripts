#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

readonly name='Tailscale'
readonly executable='tailscale'
readonly url='https://tailscale.com/install.sh'

# Local function overrides (not wrappers::curl/wrappers::wget) because the downloaded install script
# calls bare `curl`/`wget` and inherits these via `export -f` below. The full wrappers::* helpers add
# `--silent --fail` etc. which would suppress install progress output.
# wrapper around curl to disable reading the config that is intended for interactive use
function curl() {
  command curl --disable "$@"
}

# wrapper around wget to disable reading the config that is intended for interactive use
function wget() {
  command wget --no-config "$@"
}

function main() {
  if commands::executable_exists "${executable}"; then
    exit 0
  fi
  if ! prompt::yn "Install ${name}?"; then
    exit 0
  fi
  export -f curl wget
  log::log "Installing ${name} via: ${url}"
  downloads::download_and_run_script "${url}"
  log::log "Installed ${name} via: ${url}"
}

main "$@"
