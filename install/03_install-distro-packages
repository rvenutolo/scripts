#!/usr/bin/env bash

# @description Interactively install the curated distro package list for the detected OS via apt, dnf, or pacman.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

if ! prompt::yn 'Install distro packages?'; then
  exit 0
fi

files::create_temp packages_tmp
# shellcheck disable=SC2154 # packages_tmp assigned by files::create_temp nameref
packages::get_distro "$(os::id)" "$(os::codename)" > "${packages_tmp}"
mapfile -t packages < "${packages_tmp}"
readonly packages

if commands::executable_exists 'apt'; then
  sudo apt install --install-recommends --yes "${packages[@]}"
elif commands::executable_exists 'dnf'; then
  sudo dnf install --assumeyes "${packages[@]}"
elif commands::executable_exists 'pacman'; then
  sudo pacman --sync --needed --noconfirm "${packages[@]}"
fi
