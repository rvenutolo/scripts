#!/usr/bin/env bash

# @description Add the Webmin apt/dnf repo via the upstream setup script and install Webmin (servers on Debian/Ubuntu/Fedora).
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is not statically followable
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

readonly name='Webmin'
readonly executable='webmin'
readonly url='https://raw.githubusercontent.com/webmin/webmin/master/webmin-setup-repos.sh'

# Local function overrides (not http::curl/http::wget) because the downloaded install script
# calls bare `curl`/`wget` and inherits these via `export -f` below. The full http::* helpers add
# `--silent --fail` etc. which would suppress install progress output.
# @description Wrapper around the system curl that passes --disable so the downloaded installer (which calls bare `curl`) does not read the user's ~/.curlrc.
# @arg $@ args Forwarded verbatim to curl.
function curl() {
  command curl --disable "$@"
}

# @description Wrapper around the system wget that passes --no-config so the downloaded installer (which calls bare `wget`) does not read the user's ~/.wgetrc.
# @arg $@ args Forwarded verbatim to wget.
function wget() {
  command wget --no-config "$@"
}

function main() {
  if ! hosts::is_server; then
    exit 0
  fi
  if os::is_debian || os::is_ubuntu || os::is_fedora; then
    :
  elif os::is_arch || os::is_cachyos || os::is_leap || os::is_tumbleweed; then
    exit 0
  else
    log::die "Unexpected distro: $(os::id)"
  fi
  if commands::executable_exists "${executable}"; then
    exit 0
  fi
  if ! prompt::yn "Install ${name}?"; then
    exit 0
  fi
  export -f curl wget
  log::log "Adding ${name} repo"
  downloads::download_and_run_script_as_root "${url}" --force
  log::log "Added ${name} repo"
  log::log "Installing ${name}"
  if commands::executable_exists 'apt'; then
    sudo apt install --yes --install-recommends 'webmin'
  elif commands::executable_exists 'dnf'; then
    sudo dnf install --assumeyes 'webmin'
  else
    log::die 'Expected either apt or dnf to be available'
  fi
  log::log "Installed ${name}"
}

main "$@"
