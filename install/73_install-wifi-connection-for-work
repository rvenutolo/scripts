#!/usr/bin/env bash

# @description Install the encrypted NetworkManager WIFI connection profile for the work office (work hosts only).
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

if ! hosts::is_work; then
  exit 0
fi

readonly connection_file_url='https://raw.githubusercontent.com/rvenutolo/crypt/main/misc/de-400.nmconnection'
readonly connection_file='/etc/NetworkManager/system-connections/de-400.nmconnection'

if files::exists "${connection_file}"; then
  exit 0
fi

if ! prompt::yn 'Install DE WIFI connection file?'; then
  exit 0
fi

log::log 'Installing DE WIFI connection file'
files::root_write "${connection_file}" "$(download-decrypt "${connection_file_url}")"
sudo chmod 600 "${connection_file}"
log::log 'Installed DE WIFI connection file'
