{
  "name": "protect-main",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~DEFAULT_BRANCH"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_signatures" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": ["merge"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          { "context": "actionlint" },
          { "context": "bats" },
          { "context": "check-jsonschema" },
          { "context": "check-protect-main" },
          { "context": "check-scripts" },
          { "context": "commitlint" },
          { "context": "dependency-review" },
          { "context": "editorconfig" },
          { "context": "gitleaks" },
          { "context": "harden-runner-first" },
          { "context": "lint-pr-title" },
          { "context": "markdownlint" },
          { "context": "min-permissions" },
          { "context": "nix-flake-check" },
          { "context": "pr-workflows-no-secrets" },
          { "context": "renovate-invariants" },
          { "context": "required-checks-no-paths" },
          { "context": "typos" },
          { "context": "uses-sha-pinned" },
          { "context": "yaml + json lint" },
          { "context": "zizmor" }
        ]
      }
    }
  ]
}
