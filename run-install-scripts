#!/usr/bin/env bash

# @description Provision a new machine by running every executable file under install/ in LC_COLLATE=C order. Sources ~/.profile so environment vars used by the install scripts are available, then validates sudo before iterating.
# @noargs
# @exitcode 0 All install scripts completed successfully.
# @exitcode 1 sudo validation failed or one of the install scripts exited non-zero.

set -Eeuo pipefail
IFS=$'\n\t'

if [[ -f "${HOME}/.profile" ]]; then
  # shellcheck disable=SC1091
  source "${HOME}/.profile"
fi

#shellcheck disable=SC1091,SC2153
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

sudo --validate

readonly scripts_dir="${SCRIPTS_DIR}/install"
export LC_COLLATE='C'
for script in "${scripts_dir}"/*; do
  # don't attempt to execute directories, READMEs, or scripts that intentionally have their executability turned off
  if files::is_executable "${script}"; then
    log::log "Running: ${script#"${scripts_dir}"/}"
    "${script}"
    log::log "Ran: ${script#"${scripts_dir}"/}"
  fi
done
