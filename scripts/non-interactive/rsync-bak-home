#!/usr/bin/env bash

# @description Back up `$HOME` via `rsync-bak`, excluding `.cache/` and `VMs/`.
# @arg $@ args Destination path and any additional `rsync` options to forward to `rsync-bak`.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_at_least_1_arg "$@"

rsync-bak \
  --exclude '.cache/' \
  --exclude 'VMs/' \
  "${HOME}/" "$@"
