#!/usr/bin/env bash

# @description Prune unused SDKMAN packages and Temurin JDKs, then rewrite `.sdkmanrc` files to current Java versions.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

# Subshell isolates set +u and trap - ERR so parent strict mode is never touched.
# Both are needed: set -u and ERR trap (via -E) are inherited by subshells.
(
  set +u
  trap - ERR

  # sdkman-init.sh sources bash completion (sdkman_auto_complete=true in etc/config),
  # which calls the `complete` builtin at source time. Under topgrade's non-interactive
  # shell `complete` can be unavailable, exiting 127 and aborting the whole run via
  # inherited errexit. Stub it as a no-op — completion is useless in this script anyway.
  # shellcheck disable=SC2329 # invoked indirectly by the sourced sdkman-init.sh
  function complete() { :; }

  # shellcheck disable=SC1091 # sdkman-init.sh path is dynamic via SDKMAN_DIR env var
  source "${SDKMAN_DIR}/bin/sdkman-init.sh"

  log::log 'Pruning SDKMAN packages'
  sdkman_packages::prune_sdkman_packages
  log::log 'Pruned SDKMAN packages'

  log::log 'Pruning Temurin JDKs'
  sdkman_jdks::prune_tem_jdks
  log::log 'Pruned Temurin JDKs'

  log::log 'Rewriting .sdkmanrc files'
  sdkman::rewrite_sdkmanrc_file_java_versions
  log::log 'Rewrote .sdkmanrc files'
)
