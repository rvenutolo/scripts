#!/usr/bin/env bash

# @description List running processes sorted by descending CPU usage.
# @noargs
# @stdout `ps auxf` output sorted by CPU usage column.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

## get top process eating cpu ##
ps auxf | sort --numeric-sort --reverse --key=3
