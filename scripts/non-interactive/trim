#!/usr/bin/env bash

# @description Trim leading/trailing whitespace and collapse internal runs to single spaces on every line. Reads from stdin or from the given file.
# @arg $1 file Optional input file path. When omitted, reads from stdin instead.
# @stdout Whitespace-normalized lines.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"

if args::stdin_exists; then
  args::check_no_args "$@"
  awk '{$1=$1};1'
else
  args::check_exactly_1_arg "$@"
  readonly FILE="$1"
  awk '{$1=$1};1' "${FILE}"
fi
