#!/usr/bin/env bash

# @description Shrink a PDF by re-encoding it with Ghostscript using the /printer quality preset.
# @arg $1 input_pdf Path to the source PDF.
# @arg $2 output_pdf Path to write the compressed PDF.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_exactly_2_args "$@"
readonly INPUT_PDF="$1"
readonly OUTPUT_PDF="$2"

# https://www.digitalocean.com/community/tutorials/reduce-pdf-file-size-in-linux
gs \
  -sDEVICE=pdfwrite \
  -dCompatibilityLevel=1.4 \
  -dPDFSETTINGS=/printer \
  -dNOPAUSE \
  -dQUIET \
  -dBATCH \
  -sOutputFile="${OUTPUT_PDF}" \
  "${INPUT_PDF}"
