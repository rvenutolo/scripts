#!/usr/bin/env bash

# @description Remove all Podman containers in the `exited` or `created` state.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

containers="$(podman ps --filter=status=exited --filter=status=created --quiet)"
readonly containers
if strings::is_not_empty "${containers}"; then
  podman rm "${containers}"
fi
