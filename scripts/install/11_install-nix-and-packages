#!/usr/bin/env bash

# @description Interactively install Determinate Nix (multi-user) and then Nix home-manager with the configured package set.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

if ! commands::executable_exists 'nix' && prompt::yn 'Install Nix (Determinate, multi-user)?'; then
  log::log 'Installing Determinate Nix'
  # Determinate multi-user installer: root-owned store, nix-daemon, flakes on.
  # No manual /nix create/chown — the daemon install owns /nix as root.
  downloads::download_and_run_script \
    'https://install.determinate.systems/nix' \
    install --determinate --no-confirm
  log::log 'Installed Determinate Nix'
fi

if ! commands::executable_exists 'home-manager' && prompt::yn 'Install Nix home-manager and packages?'; then
  log::log 'Installing Nix home-manager and packages'
  # Multi-user: nix env comes from Determinate's system profile script, which
  # sources the daemon profile.d from the default profile.
  # shellcheck disable=SC1091
  source '/etc/profile.d/nix.sh'
  write-home-manager-packages
  home_manager_release="$(
    grep --only-matching --perl-regexp \
      '(?<=github:nix-community/)home-manager/release-\d{2}\.\d{2}' \
      "${HOME_MANAGER_DIR}/flake.nix"
  )"
  readonly home_manager_release
  nix run "${home_manager_release}" -- init --switch --flake "${HOME_MANAGER_DIR}"
  if commands::executable_exists 'non-nixos-gpu-setup'; then
    sudo "$(commands::executable_path 'non-nixos-gpu-setup')"
  fi
  log::log 'Installed Nix home-manager and packages'
fi
