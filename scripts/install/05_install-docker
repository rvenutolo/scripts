#!/usr/bin/env bash

# @description Interactively install Docker by running the upstream get.docker.com installer.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is not statically followable
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

readonly name='Docker'
readonly executable='dockerd'
readonly url='https://get.docker.com'

# Local function overrides (not http::curl/http::wget) because the downloaded install script
# calls bare `curl`/`wget` and inherits these via `export -f` below. The full http::* helpers add
# `--silent --fail` etc. which would suppress install progress output.
# @description Wrapper around the system curl that passes --disable so the downloaded installer (which calls bare `curl`) does not read the user's ~/.curlrc.
# @arg $@ args Forwarded verbatim to curl.
function curl() {
  command curl --disable "$@"
}

# @description Wrapper around the system wget that passes --no-config so the downloaded installer (which calls bare `wget`) does not read the user's ~/.wgetrc.
# @arg $@ args Forwarded verbatim to wget.
function wget() {
  command wget --no-config "$@"
}

function main() {
  if commands::executable_exists "${executable}"; then
    exit 0
  fi
  if ! prompt::yn "Install ${name}?"; then
    exit 0
  fi
  export -f curl wget
  log::log "Installing ${name} via: ${url}"
  downloads::download_and_run_script "${url}"
  log::log "Installed ${name} via: ${url}"
}

main "$@"
