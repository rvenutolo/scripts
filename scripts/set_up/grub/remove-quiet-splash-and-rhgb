#!/usr/bin/env bash

# @description Remove the rhgb, quiet, and splash kernel options from /etc/default/grub on server hosts and regenerate the GRUB config.
# @noargs
# @exitcode 1 The expected GRUB config or default file is missing.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

readonly KERNEL_OPTIONS_TO_REMOVE=(
  'rhgb'
  'quiet'
  'splash'
)

# @description Strip the configured kernel options from GRUB_CMDLINE_LINUX(_DEFAULT) lines on stdin.
# @noargs
function strip_kernel_options() {
  args::check_no_args "$@"
  local line line_to_write kernel_option
  while read -r line; do
    line_to_write="${line}"
    if grep::contains_perl_regex '^\s*(GRUB_CMDLINE_LINUX)|(GRUB_CMDLINE_LINUX_DEFAULT)\s*=' <<< "${line}"; then
      for kernel_option in "${KERNEL_OPTIONS_TO_REMOVE[@]}"; do
        line_to_write="${line_to_write//${kernel_option}/}"
      done
      line_to_write="$(sed 's/\s*"\s*/"/g ; s/\s\+/ /g' <<< "${line_to_write}")"
    fi
    printf '%s\n' "${line_to_write}"
  done
}

# @description Return true if the GRUB default file contains any of the configured kernel options to remove.
# @arg $1 path to GRUB default file
function grub_default_contains_options() {
  args::check_exactly_1_arg "$@"
  local -r grub_default_file="$1"
  local line options kernel_option
  while read -r line; do
    if grep::contains_perl_regex '^\s*(GRUB_CMDLINE_LINUX_DEFAULT|GRUB_CMDLINE_LINUX)\s*=' <<< "${line}"; then
      options="$(cut --delimiter='"' --fields=2 <<< "${line}")"
      for kernel_option in "${KERNEL_OPTIONS_TO_REMOVE[@]}"; do
        if printf '%s\n' "${options}" | grep::contains_word "${kernel_option}"; then
          return 0
        fi
      done
    fi
  done < "${grub_default_file}"
  return 1
}

function main() {
  args::check_no_args "$@"

  if ! hosts::is_server; then
    exit 0
  fi

  if ! commands::executable_exists 'grub-mkconfig' && ! commands::executable_exists 'grub2-mkconfig'; then
    exit 0
  fi

  # These pairings of commands and GRUB output config files may not always be
  # correct, but seem to be consistent with the distros I've looked at recently.
  local grub_mkconfig_cmd grub_config_file
  if commands::executable_exists 'grub-mkconfig'; then
    grub_mkconfig_cmd='grub-mkconfig'
    grub_config_file='/boot/grub/grub.cfg'
  else
    grub_mkconfig_cmd='grub2-mkconfig'
    grub_config_file='/boot/grub2/grub.cfg'
  fi
  readonly grub_mkconfig_cmd
  readonly grub_config_file
  files::assert_exists "${grub_config_file}"

  local -r grub_default_file='/etc/default/grub'
  files::assert_exists "${grub_default_file}"

  if ! grub_default_contains_options "${grub_default_file}"; then
    exit 0
  fi

  local -r kernel_options_to_remove_string="${KERNEL_OPTIONS_TO_REMOVE[*]}"
  if ! prompt::yn "Remove GRUB kernel options: ${kernel_options_to_remove_string// /, }"; then
    exit 0
  fi

  files::root_transform "${grub_default_file}" strip_kernel_options

  sudo "${grub_mkconfig_cmd}" --output="${grub_config_file}"
}

main "$@"
