#!/usr/bin/env bash

# @description Assert that every `actions/checkout` step — in a workflow or a
#              composite action — sets `persist-credentials: false` (literal
#              YAML bool). `actions/checkout` otherwise persists the
#              GITHUB_TOKEN in `.git/config`, where any later step (including
#              one running untrusted code) can read it. This lint locks in the
#              repo's existing posture so a future checkout can't regress.
# @noargs
# @stderr One line per offending checkout step, plus a final count.
# @exitcode 0 every actions/checkout step sets persist-credentials: false.
# @exitcode 1 one or more checkout steps omit it.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"
commands::assert_executable_exists 'yq'

REPO_DIR="$(git rev-parse --show-toplevel)"
readonly REPO_DIR
readonly WORKFLOWS_DIR="${WORKFLOWS_DIR_OVERRIDE:-${REPO_DIR}/.github/workflows}"
readonly ACTIONS_DIR="${ACTIONS_DIR_OVERRIDE:-${REPO_DIR}/.github/actions}"

# @description Emit a descriptor line for every `actions/checkout` step in the
#              given YAML file that does NOT set `persist-credentials: false`
#              as a literal bool. Handles both workflow shape (`.jobs[].steps[]`)
#              and composite-action shape (`.runs.steps[]`) in one pass; a
#              missing path contributes nothing. The `tag == "!!bool"` guard is
#              required because yq coerces `"false" != false` to false, so a
#              bare `!= false` would wrongly accept the string "false".
# @arg $1 file path to a workflow or action YAML
# @stdout One line (step name, or `uses` as fallback) per offending step.
function offending_checkout_steps() {
  args::check_exactly_1_arg "$@"
  local -r file="$1"
  yq eval '
    [ .jobs[]?.steps[]?, .runs.steps[]? ] | .[]
      | select(.uses // "" | test("^actions/checkout@"))
      | select(((.with."persist-credentials" | tag) != "!!bool")
               or (.with."persist-credentials" != false))
      | (.name // .uses)
  ' "${file}"
}

function main() {
  args::check_no_args "$@"
  local files_tmp
  files::create_temp files_tmp
  local dir
  for dir in "${WORKFLOWS_DIR}" "${ACTIONS_DIR}"; do
    if dirs::exists "${dir}"; then
      find "${dir}" -type f \( -name '*.yml' -o -name '*.yaml' \) >> "${files_tmp}"
    fi
  done
  local total=0
  local file
  local steps_tmp
  local step
  while IFS= read -r file; do
    strings::is_empty "${file}" && continue
    files::create_temp steps_tmp
    offending_checkout_steps "${file}" > "${steps_tmp}"
    while IFS= read -r step; do
      strings::is_empty "${step}" && continue
      printf "%s: actions/checkout step '%s' omits persist-credentials: false\n" \
        "${file}" "${step}" >&2
      total=$((total + 1))
    done < "${steps_tmp}"
  done < "${files_tmp}"
  if ((total > 0)); then
    printf '%d actions/checkout step(s) omit persist-credentials: false\n' "${total}" >&2
    exit 1
  fi
  exit 0
}

main "$@"
