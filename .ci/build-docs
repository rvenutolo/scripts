#!/usr/bin/env bash

# @description Generate markdown reference docs for the scripts repo by running
#              shdoc against every functions/*.bash file and every shell script
#              under main/. Output lands in docs/functions/ and docs/scripts/
#              (gitignored, regenerated on every build). Companion config:
#              .mkdocs.yml. Companion deploy: .github/workflows/pages.yml.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 3
args::check_no_args "$@"

readonly SHDOC="${SCRIPTS_DIR}/.shdoc/shdoc"
readonly DOCS_FUNCTIONS_DIR="${SCRIPTS_DIR}/docs/functions"
readonly DOCS_SCRIPTS_DIR="${SCRIPTS_DIR}/docs/scripts"

# @description Wipe and recreate output directories so each build is clean.
function reset_output_dirs() {
  rm --recursive --force -- "${DOCS_FUNCTIONS_DIR}" "${DOCS_SCRIPTS_DIR}"
  dirs::create "${DOCS_FUNCTIONS_DIR}"
  dirs::create "${DOCS_SCRIPTS_DIR}"
}

# @description Run shdoc on a file and write its markdown to the destination.
# @arg $1 src source bash file
# @arg $2 dest destination markdown file
function shdoc_one() {
  args::check_exactly_2_args "$@"
  local -r src="$1"
  local -r dest="$2"
  gawk -f "${SHDOC}" < "${src}" > "${dest}"
}

# @description Render the file-level shdoc header of a top-level script to markdown: title (basename),
#              Overview (@description), Arguments (@arg / @noargs), Stdout (@stdout), Stderr (@stderr),
#              Exit codes (@exitcode), Example (@example). shdoc itself only emits @description at the
#              file level, dropping every other file-level tag — this awk pass fills that gap. Reads
#              header tags between the shebang and the first `set -E...` line (the standard top-level
#              skeleton enforced by CLAUDE.md).
# @arg $1 src source bash file
# @arg $2 title page title (script basename)
function render_script_header() {
  args::check_exactly_2_args "$@"
  local -r src="$1"
  local -r title="$2"
  gawk -v title="${title}" '
    /^[[:space:]]*set[[:space:]]+-/ { exit }
    /^[[:space:]]*# @description/ {
      sub(/^[[:space:]]*# @description[[:space:]]*/, "")
      desc = $0
      in_desc = 1
      in_example = 0
      next
    }
    in_desc {
      if (/^[[:space:]]*#[[:space:]]+[^@]/) {
        line = $0
        sub(/^[[:space:]]*#[[:space:]]+/, "", line)
        desc = desc " " line
        next
      }
      in_desc = 0
    }
    /^[[:space:]]*# @arg[[:space:]]/ {
      sub(/^[[:space:]]*# @arg[[:space:]]+/, "")
      args_a[++narg] = $0
      in_example = 0
      next
    }
    /^[[:space:]]*# @noargs[[:space:]]*$/ {
      noargs = 1
      in_example = 0
      next
    }
    /^[[:space:]]*# @exitcode[[:space:]]/ {
      sub(/^[[:space:]]*# @exitcode[[:space:]]+/, "")
      ecs[++nec] = $0
      in_example = 0
      next
    }
    /^[[:space:]]*# @stdout[[:space:]]/ {
      sub(/^[[:space:]]*# @stdout[[:space:]]+/, "")
      sos[++nso] = $0
      in_example = 0
      next
    }
    /^[[:space:]]*# @stderr[[:space:]]/ {
      sub(/^[[:space:]]*# @stderr[[:space:]]+/, "")
      ses[++nse] = $0
      in_example = 0
      next
    }
    /^[[:space:]]*# @example[[:space:]]*$/ {
      in_example = 1
      next
    }
    in_example {
      if (/^[[:space:]]*#[[:space:]]/) {
        line = $0
        sub(/^[[:space:]]*#[[:space:]]?/, "", line)
        ex = (ex == "" ? line : ex "\n" line)
        next
      }
      in_example = 0
    }
    END {
      printf("# %s\n\n", title)
      if (desc != "") {
        printf("## Overview\n\n%s\n\n", desc)
      }
      if (noargs) {
        printf("## Arguments\n\nNone.\n\n")
      } else if (narg > 0) {
        printf("## Arguments\n\n")
        for (i = 1; i <= narg; i++) {
          if (match(args_a[i], /^(\$[0-9@]+)[[:space:]]+([^[:space:]]+)[[:space:]]+(.*)$/, m)) {
            printf("- **%s** (`%s`): %s\n", m[1], m[2], m[3])
          } else if (match(args_a[i], /^(\$[0-9@]+)[[:space:]]+(.*)$/, m)) {
            printf("- **%s**: %s\n", m[1], m[2])
          } else {
            printf("- %s\n", args_a[i])
          }
        }
        printf("\n")
      }
      if (nso > 0) {
        printf("## Stdout\n\n")
        for (i = 1; i <= nso; i++) printf("- %s\n", sos[i])
        printf("\n")
      }
      if (nse > 0) {
        printf("## Stderr\n\n")
        for (i = 1; i <= nse; i++) printf("- %s\n", ses[i])
        printf("\n")
      }
      if (nec > 0) {
        printf("## Exit codes\n\n")
        for (i = 1; i <= nec; i++) {
          if (match(ecs[i], /^([0-9]+)[[:space:]]+(.*)$/, m)) {
            printf("- **%s**: %s\n", m[1], m[2])
          } else {
            printf("- %s\n", ecs[i])
          }
        }
        printf("\n")
      }
      if (ex != "") {
        printf("## Example\n\n```bash\n%s\n```\n\n", ex)
      }
    }
  ' "${src}"
}

# @description Render markdown for a top-level script: a hand-rolled file-level header (covering every
#              shdoc tag, not just @description) followed by shdoc output of the raw source so any
#              inner helper-function docblocks still render.
# @arg $1 src source bash file
# @arg $2 dest destination markdown file
function shdoc_script_one() {
  args::check_exactly_2_args "$@"
  local -r src="$1"
  local -r dest="$2"
  local -r title="$(basename -- "${src}")"
  {
    render_script_header "${src}" "${title}"
    gawk -f "${SHDOC}" < "${src}"
  } > "${dest}"
}

# @description Generate one markdown index file listing the per-file pages.
# @arg $1 dir docs subdirectory containing per-file .md pages (no index.md yet)
# @arg $2 title H1 title for the index page
function write_index() {
  args::check_exactly_2_args "$@"
  local -r dir="$1"
  local -r title="$2"
  local -r index="${dir}/index.md"
  local _entries_file
  files::create_temp _entries_file
  find "${dir}" -maxdepth 1 -type f -name '*.md' ! -name 'index.md' | sort > "${_entries_file}"
  {
    printf '# %s\n\n' "${title}"
    local entry base
    while IFS= read -r entry; do
      base="$(basename -- "${entry}" .md)"
      printf -- '- [%s](%s)\n' "${base}" "${entry##*/}"
    done < "${_entries_file}"
  } > "${index}"
}

# @description Generate per-script markdown for every script returned by the
#              given enumerator command, into ${DOCS_SCRIPTS_DIR}/${out_subdir}/,
#              and write a per-subdir index.md with the given title.
# @arg $1 enumerator name of the function to invoke for script paths on stdout
#         (e.g. shell_scripts::find or shell_scripts::find_root_only)
# @arg $2 enumerator_arg argument passed to the enumerator function (use '' when
#         the enumerator takes no arg, e.g. find_root_only)
# @arg $3 out_subdir subdirectory under DOCS_SCRIPTS_DIR (e.g. main, install)
# @arg $4 title H1 title for the subdir's index page
function generate_scripts_for_dir() {
  args::check_exactly_4_args "$@"
  local -r enumerator="$1"
  local -r enumerator_arg="$2"
  local -r out_subdir="$3"
  local -r title="$4"
  local -r out_dir="${DOCS_SCRIPTS_DIR}/${out_subdir}"
  dirs::create "${out_dir}"
  local list_file
  files::create_temp list_file
  if strings::is_empty "${enumerator_arg}"; then
    "${enumerator}" > "${list_file}"
  else
    "${enumerator}" "${enumerator_arg}" > "${list_file}"
  fi
  local script base
  while IFS= read -r script; do
    base="$(basename -- "${script}")"
    shdoc_script_one "${script}" "${out_dir}/${base}.md"
  done < "${list_file}"
  write_index "${out_dir}" "${title}"
}

# @description Write the top-level scripts index that links to each
#              per-directory index.
# @noargs
# shellcheck disable=SC2120 # args::check_no_args "$@" is the repo's no-args guard; SC2120 is a false positive
function write_scripts_top_index() {
  args::check_no_args "$@"
  local -r index="${DOCS_SCRIPTS_DIR}/index.md"
  {
    printf '# Scripts\n\n'
    local subdir
    for subdir in main install set_up misc root; do
      if files::exists "${DOCS_SCRIPTS_DIR}/${subdir}/index.md"; then
        printf -- '- [%s](%s/index.md)\n' "${subdir}" "${subdir}"
      fi
    done
  } > "${index}"
}

# @description Build the home page from README.md so the site has a familiar
#              landing page. MkDocs adds the chrome around it.
# @noargs
function write_home_index() {
  cp -- "${SCRIPTS_DIR}/README.md" "${SCRIPTS_DIR}/docs/index.md"
}

function main() {
  args::check_no_args "$@"
  if ! files::exists "${SHDOC}"; then
    log::die "shdoc not found at ${SHDOC} — run: git submodule update --init --recursive"
  fi
  if ! commands::executable_exists gawk; then
    log::die "gawk not found on PATH"
  fi

  reset_output_dirs
  dirs::create "${SCRIPTS_DIR}/docs"

  log::log "Generating function reference"
  local file base
  for file in "${SCRIPTS_DIR}"/functions/*.bash; do
    base="$(basename -- "${file}" .bash)"
    shdoc_one "${file}" "${DOCS_FUNCTIONS_DIR}/${base}.md"
  done
  write_index "${DOCS_FUNCTIONS_DIR}" 'Functions'

  log::log "Generating scripts reference"
  generate_scripts_for_dir shell_scripts::find "${SCRIPTS_DIR}/main" main 'main'
  generate_scripts_for_dir shell_scripts::find "${SCRIPTS_DIR}/install" install 'install'
  generate_scripts_for_dir shell_scripts::find "${SCRIPTS_DIR}/set_up" set_up 'set_up'
  generate_scripts_for_dir shell_scripts::find "${SCRIPTS_DIR}/misc" misc 'misc'
  generate_scripts_for_dir shell_scripts::find_root_only '' root 'root'
  # shellcheck disable=SC2119 # no args passed; args::check_no_args "$@" is the repo's no-args guard
  write_scripts_top_index

  log::log "Generating home page from README.md"
  write_home_index

  log::log "Doc generation complete: ${SCRIPTS_DIR}/docs/"
}

main "$@"
