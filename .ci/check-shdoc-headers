#!/usr/bin/env bash

# @description Audit every shebang-bearing executable under main/, wrapper/,
#              install/, set_up/, misc/, and the project root AND every library file
#              under functions/ for the project's shdoc annotation convention.
#              Top-level scripts must carry a file-level `# @description` tag
#              in the header and an annotation block on every helper function
#              other than `main`. Library files (functions/*.bash) must have
#              an annotation block on every function — the file-level
#              description is intentionally not required because library files
#              are documented function-by-function.
# @noargs
# @stdout Empty on success. On failure: one block per failing file with the
#         missing-header reason and any unannotated function names.
# @exitcode 0 every in-scope file passes the appropriate annotation rule.
# @exitcode 1 one or more files are missing required shdoc annotations.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 3
args::check_no_args "$@"

# @description Print every in-scope top-level script path, one per line.
#              In-scope means any shebang-bearing file under main/, wrapper/,
#              install/, set_up/, misc/, .ci/, or directly under SCRIPTS_DIR (project
#              root). Library files under functions/ are listed by
#              collect_library_files instead, since they follow a different
#              annotation rule.
# @noargs
# @stdout File paths, one per line.
# shellcheck disable=SC2120 # called with no args by callers, shellcheck can't see all call sites
function collect_in_scope_scripts() {
  args::check_no_args "$@"
  local subdir
  for subdir in main wrapper install set_up misc .ci; do
    if dirs::exists "${SCRIPTS_DIR}/${subdir}"; then
      shell_scripts::find "${SCRIPTS_DIR}/${subdir}"
    fi
  done
  shell_scripts::find_root_only
}

# @description Print every library file path under functions/, one per line.
#              Library files are audited under a different rule than top-level
#              scripts: per-function annotations only, no file-level
#              @description.
# @noargs
# @stdout File paths, one per line.
# shellcheck disable=SC2120 # called with no args by callers
function collect_library_files() {
  args::check_no_args "$@"
  local file
  for file in "${SCRIPTS_DIR}"/functions/*.bash; do
    if files::exists "${file}"; then
      printf '%s\n' "${file}"
    fi
  done
}

# @description Audit a single top-level script. Print a block on stderr if
#              it lacks a file-level @description or has any unannotated
#              helper functions other than `main`.
# @arg $1 file path to script
# @exitcode 0 clean
# @exitcode 1 reported violations
function audit_one() {
  args::check_exactly_1_arg "$@"
  local -r file="$1"
  local violations=()
  if ! shdoc::file_has_description "${file}"; then
    violations+=('missing file-level @description')
  fi
  local unannotated_file
  files::create_temp unannotated_file
  shdoc::find_unannotated_functions "${file}" > "${unannotated_file}"
  if [[ -s "${unannotated_file}" ]]; then
    local fn
    while IFS= read -r fn; do
      violations+=("helper function missing shdoc annotation: ${fn}")
    done < "${unannotated_file}"
  fi
  if [[ "${#violations[@]}" -eq 0 ]]; then
    return 0
  fi
  printf '%s\n' "${file}" >&2
  local v
  for v in "${violations[@]}"; do
    printf '  - %s\n' "${v}" >&2
  done
  return 1
}

# @description Audit a single library file under functions/. Library files
#              are documented per-function, so the file-level @description
#              check is skipped — only unannotated functions are flagged.
# @arg $1 file path to library file
# @exitcode 0 clean
# @exitcode 1 reported violations
function audit_library_one() {
  args::check_exactly_1_arg "$@"
  local -r file="$1"
  local unannotated_file
  files::create_temp unannotated_file
  shdoc::find_unannotated_functions "${file}" > "${unannotated_file}"
  if [[ ! -s "${unannotated_file}" ]]; then
    return 0
  fi
  printf '%s\n' "${file}" >&2
  local fn
  while IFS= read -r fn; do
    printf '  - %s\n' "function missing shdoc annotation: ${fn}" >&2
  done < "${unannotated_file}"
  return 1
}

function main() {
  args::check_no_args "$@"
  local rc=0

  local scripts_file
  files::create_temp scripts_file
  # shellcheck disable=SC2119 # no args intended; SC2120 disable on function def suppresses the pair
  collect_in_scope_scripts > "${scripts_file}"
  local script
  while IFS= read -r script; do
    if ! audit_one "${script}"; then
      rc=1
    fi
  done < "${scripts_file}"

  local lib_file
  files::create_temp lib_file
  # shellcheck disable=SC2119 # no args intended
  collect_library_files > "${lib_file}"
  local lib
  while IFS= read -r lib; do
    if ! audit_library_one "${lib}"; then
      rc=1
    fi
  done < "${lib_file}"

  if ((rc != 0)); then
    log::warn 'shdoc header audit failed — see above for details.'
  fi
  exit "${rc}"
}

main "$@"
