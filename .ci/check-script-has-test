#!/usr/bin/env bash

# @description Assert every shebang-bearing executable under .ci/ has a paired
#              test/ci/<name>.bats file. Mirrors the BATS-coverage mandate that
#              already applies to functions/*.bash. Explicitly side-effecting
#              scripts that cannot be deterministically tested are exempted via
#              a hardcoded list.
# @noargs
# @stderr One line per .ci/ script missing its paired test/ci/<name>.bats.
# @exitcode 0 every non-exempt .ci/ script has a paired test.
# @exitcode 1 one or more .ci/ scripts are missing a paired test.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"

REPO_DIR="$(git rev-parse --show-toplevel)"
readonly REPO_DIR
readonly CI_DIR="${CI_DIR_OVERRIDE:-${REPO_DIR}/.ci}"
readonly TEST_CI_DIR="${TEST_CI_DIR_OVERRIDE:-${REPO_DIR}/test/ci}"

# Scripts exempt from the paired-test mandate:
# - apply-repo-settings: mutates the live GitHub repo via the gh API; it is
#   side-effecting, not CI-run, and has nothing deterministic to assert.
readonly EXEMPT=(apply-repo-settings)

# @description Return true if the given basename is in the EXEMPT list.
# @arg $1 name basename of a .ci/ script
# @exitcode 0 name is exempt
# @exitcode 1 name is not exempt
function is_exempt() {
  args::check_exactly_1_arg "$@"
  local -r name="$1"
  local exempt
  for exempt in "${EXEMPT[@]}"; do
    if [[ "${name}" == "${exempt}" ]]; then
      return 0
    fi
  done
  return 1
}

function main() {
  args::check_no_args "$@"
  local scripts_file
  files::create_temp scripts_file
  shell_scripts::find "${CI_DIR}" > "${scripts_file}"
  local failed=0
  local script name
  while IFS= read -r script; do
    strings::is_empty "${script}" && continue
    name="$(basename "${script}")"
    if is_exempt "${name}"; then
      continue
    fi
    if ! files::exists "${TEST_CI_DIR}/${name}.bats"; then
      printf '%s: no paired test/ci/%s.bats\n' "${name}" "${name}" >&2
      failed=1
    fi
  done < "${scripts_file}"
  exit "${failed}"
}

main "$@"
