#!/usr/bin/env bash

# @description Assert that no GitHub Actions workflow triggered by
#              `pull_request` or `pull_request_target` references any
#              `secrets.*` other than `secrets.GITHUB_TOKEN`. PR-triggered
#              workflows can run from forks, so exposing custom secrets to
#              them is a credential-exfiltration risk.
# @noargs
# @stderr One line per violation, plus a final count.
# @exitcode 0 no PR-triggered workflow references a disallowed secret.
# @exitcode 1 one or more disallowed secret references found.

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced from SCRIPTS_DIR at runtime
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
args::check_no_args "$@"
commands::assert_executable_exists 'yq'

REPO_DIR="$(git rev-parse --show-toplevel)"
readonly REPO_DIR
readonly WORKFLOWS_DIR="${WORKFLOWS_DIR_OVERRIDE:-${REPO_DIR}/.github/workflows}"

# @description Determine whether a workflow is triggered by `pull_request` or
#              `pull_request_target`. Handles all three shapes of `.on`:
#              scalar (`on: pull_request`), sequence
#              (`on: [push, pull_request]`), and map (`on:\n  pull_request:`).
# @arg $1 file path to a workflow YAML
# @exitcode 0 workflow is PR-triggered.
# @exitcode 1 workflow is not PR-triggered.
function is_pr_triggered() {
  args::check_exactly_1_arg "$@"
  local -r file="$1"
  local triggers_tmp
  files::create_temp triggers_tmp
  # Emit every trigger name regardless of `.on` shape: map keys, sequence
  # members, and a bare scalar. Each branch is guarded by select(type) so the
  # other two shapes contribute nothing instead of erroring.
  yq eval '
    (.on | select(type == "!!map") | keys | .[]),
    (.on | select(type == "!!seq") | .[]),
    (.on | select(type == "!!str"))
  ' "${file}" > "${triggers_tmp}"
  grep --line-regexp --quiet --extended-regexp 'pull_request|pull_request_target' "${triggers_tmp}"
}

# @description Scan a PR-triggered workflow for disallowed `secrets.*`
#              references. Prints violations to stderr; echoes the violation
#              count to stdout.
# @arg $1 file path to a workflow YAML
# @stdout integer violation count
function scan_secrets() {
  args::check_exactly_1_arg "$@"
  local -r file="$1"
  local matches_tmp
  files::create_temp matches_tmp
  # `secrets.GITHUB_TOKEN` is the one auto-provisioned, fork-safe token; every
  # other secret reference is flagged.
  grep --line-number --only-matching --extended-regexp 'secrets\.[A-Za-z0-9_]+' "${file}" \
    > "${matches_tmp}" || true
  local count=0
  local lineno secret
  while IFS=':' read -r lineno secret; do
    strings::is_empty "${secret}" && continue
    if [[ "${secret}" == 'secrets.GITHUB_TOKEN' ]]; then
      continue
    fi
    printf '%s:%s: %s not allowed in PR-triggered workflow\n' "${file}" "${lineno}" "${secret}" >&2
    count=$((count + 1))
  done < "${matches_tmp}"
  printf '%s\n' "${count}"
}

function main() {
  args::check_no_args "$@"
  if ! dirs::exists "${WORKFLOWS_DIR}"; then
    exit 0
  fi
  local files_tmp
  files::create_temp files_tmp
  find "${WORKFLOWS_DIR}" -type f \( -name '*.yml' -o -name '*.yaml' \) > "${files_tmp}"
  local total=0
  local file n
  while IFS= read -r file; do
    strings::is_empty "${file}" && continue
    if is_pr_triggered "${file}"; then
      n="$(scan_secrets "${file}")"
      total=$((total + n))
    fi
  done < "${files_tmp}"
  if ((total > 0)); then
    printf '%d disallowed secret reference(s) in PR-triggered workflow(s)\n' "${total}" >&2
    exit 1
  fi
  exit 0
}

main "$@"
