#!/usr/bin/env bash

# @description Symlink the Nix user profile fonts directory into the user's XDG fonts directory and refresh the font cache.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # .functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/.functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

if ! dirs::exists "${NIX_USER_PROFILE}/share/fonts"; then
  exit 0
fi
if symlinks::exists "${XDG_DATA_HOME}/fonts/nix"; then
  exit 0
fi
if ! prompt::yn 'Link Nix fonts and update font cache?'; then
  exit 0
fi

log::log 'Updating font cache to include nixpkgs fonts'
dirs::create "${XDG_DATA_HOME}/fonts"
symlinks::link_dir "${NIX_USER_PROFILE}/share/fonts" "${XDG_DATA_HOME}/fonts/nix"
fc-cache --force
log::log 'Updated font cache to include nixpkgs fonts'
