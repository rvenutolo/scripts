#!/usr/bin/env bash

# @description Remove ~/.bash_logout if it exists, prompting the user for confirmation before deletion.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

readonly bash_logout_file="${HOME}/.bash_logout"

if ! files::exists "${bash_logout_file}"; then
  exit 0
fi
if ! prompt::yn "Delete ${bash_logout_file}?"; then
  exit 0
fi

log::log "Removing: ${bash_logout_file}"
rm -- "${bash_logout_file}"
log::log "Removed: ${bash_logout_file}"
