#!/usr/bin/env bash

# @description Interactively set the system timezone via timedatectl, defaulting to America/New_York.
# @arg $1 tz optional timezone name (default: America/New_York)
# @exitcode 0 timezone already matches, prompt declined, or set successfully

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # source path not known statically
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_at_most_1_arg "$@"

if args::no_args "$@"; then
  readonly tz='America/New_York'
else
  readonly tz="$1"
fi

if timedatectl show | grep::contains_regex "^Timezone=${tz}$"; then
  exit 0
fi
if ! prompt::yn "Set timezone to: ${tz}"; then
  exit 0
fi

log::log "Setting timezone to: ${tz}"
sudo timedatectl set-timezone "${tz}"
log::log "Set timezone to: ${tz}"
