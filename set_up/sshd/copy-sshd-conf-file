#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

#shellcheck disable=SC1091
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
system::require_bash_version 4 0
args::check_no_args "$@"

if ! dirs::exists '/etc/ssh/sshd_config.d'; then
  log::die '/etc/ssh/sshd_config.d does not exist'
fi

readonly src_file="${HOME}/.etc/sshd.conf"
readonly dest_file='/etc/ssh/sshd_config.d/sshd.conf'

orig_hash="$(files::hash "${dest_file}")" || exit 1
readonly orig_hash
files::root_copy "${src_file}" "${dest_file}"
cur_hash="$(files::hash "${dest_file}")" || exit 1
readonly cur_hash

if [[ "${orig_hash}" != "${cur_hash}" ]]; then
  systemctl::restart_system_service_if_enabled 'sshd.service'
fi
