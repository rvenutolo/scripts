#!/usr/bin/env bash

# @description Interactively add the RPM Fusion free and nonfree repositories on Fedora hosts.
# @noargs

set -Eeuo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091 # functions.bash is sourced via SCRIPTS_DIR, not a relative path
source "${SCRIPTS_DIR}/functions.bash"
log::enable_err_trap
args::handle_help_flag "$@"
system::require_bash_version 4 0
args::check_no_args "$@"

if ! os::is_fedora; then
  exit 0
fi

if ! commands::executable_exists 'dnf'; then
  log::log 'dnf executable not found'
  exit 0
fi

if ! prompt::yn 'Add RPM Fusion repos?'; then
  exit 0
fi

for repo in 'rpmfusion-free-release' 'rpmfusion-nonfree-release'; do
  if ! dnf list --installed "${repo}" > '/dev/null' 2>&1 && prompt::yn "Add ${repo} repository?"; then
    if [[ "${repo}" == 'rpmfusion-free-release' ]]; then
      sudo dnf install "https://mirrors.rpmfusion.org/free/fedora/${repo}-$(rpm --eval='%fedora').noarch.rpm"
    else
      sudo dnf install "https://mirrors.rpmfusion.org/nonfree/fedora/${repo}-$(rpm --eval='%fedora').noarch.rpm"
    fi
  fi
done
